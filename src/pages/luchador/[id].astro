---
import { FIGHTERS } from "@/consts/fighters";
import Layout from "@/layouts/Layout.astro";

const { id } = Astro.params;

const fighter = FIGHTERS.find((fighter) => fighter.id === id);

export const prerender = false;
---

<Layout>
  <section
    class="relative flex min-h-screen justify-center w-full px-"
    id="hero"
  >
    <div
      class="bg-[url('/images/hero.webp')] bg-cover bg-center w-full mask-fade-bottom absolute inset-0"
    >
    </div>
    <img
      transition:name={`image-${id}`}
      data-id={`hero-image-${id}`}
      src={`/images/fighters/big/${id}.webp`}
      alt={fighter?.name}
      class="w-auto h-[70%]"
    />
  </section>
</Layout>
