---
import './src/styles/global.css';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>
			La Velada del año V - Evento de boxeo de Ibai Llanos con creadores de contenido
		</title>

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<meta
			name="description"
			content="Evento de boxeo aficionado entre stramers y creadores de contenido, organizado por Ibai Llanos"
		/>

		<meta property="og:url" content="https://www.infolavelada.com">
		<meta property="og:type" content="website">
		<meta property="og:title" content="La Velada del año V de Ibai Llanos">
		<meta 
			property="og:description" 
			content="Evento de boxeo aficiondo entre streamers y creadores de contenido, organizado por Ibai Llanos"
		>
		<meta property="og:image" content="https://www.infolavelada.com/og.jpg" />
		<meta property="og:locale" content="es_ES" />


		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:url" content="https://www.infolavelada.com">
		<meta name="twitter:type" content="website">
		<meta name="twitter:site" content="@infoLaVelada">
		<meta name="twitter:creator" content="@ibaiLlanos">
		<meta name="twitter:title" content="La Velada del año V de Ibai Llanos">
		<meta name="twitter:description" content="Evento de boxeo aficionado entre stramers y creadores de contenido, organizado por Ibai Llanos">

	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	* {
		margin: 0;
		padding: 0;
	}
	html,
	body {
		background-color: #f19fca;
	}
</style>
